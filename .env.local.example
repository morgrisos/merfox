# MerFox PA-API 認証情報テンプレート
# このファイルをコピーして .env.local として保存し、中身を埋めてください。
# .env.local は .gitignore 対象です。コミット禁止。
#
# 使い方：
#   cp .env.local.example .env.local
#   エディタで各変数に実際の値を入力

# -----------------------------------------------
# Amazon Product Advertising API 5.0 認証情報
# 取得先: https://affiliate.amazon.co.jp/assoc_credentials/home
# -----------------------------------------------
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_PAAPI_PARTNER_TAG=

# PA-API エンドポイント設定 (通常変更不要)
AMAZON_PAAPI_REGION=us-east-1
AMAZON_PAAPI_HOST=webservices.amazon.co.jp

# -----------------------------------------------
# プロバイダ切替
# mock  : テスト用モックデータ (デフォルト・キー不要)
# paapi : Amazon PA-API 5.0 (上記キーが必要)
# -----------------------------------------------
SEARCH_PROVIDER=paapi

# -----------------------------------------------
# JWT署名検証シークレット
# VPS の lite-server.js の JWT_SECRET と同じ値を設定する
# ビルド前に必ず設定すること（next build 時に server バンドルへ bake-in される）
# -----------------------------------------------
MERFOX_JWT_SECRET=

# -----------------------------------------------
# Apple Notarization (Mac配布ビルド時のみ必要)
# 取得先: https://developer.apple.com
# -----------------------------------------------
# Apple Developer アカウントのメールアドレス
APPLE_ID=

# App-Specific Password (appleid.apple.com → セキュリティ → App用パスワード)
APPLE_APP_SPECIFIC_PASSWORD=

# Team ID (developer.apple.com/account → Membership → Team ID: 10文字英数)
APPLE_TEAM_ID=

# Developer ID Application 証明書の Common Name (署名に使用)
# 例: Developer ID Application: Your Name (XXXXXXXXXX)
# Keychain Access で確認 → 証明書カテゴリ → Developer ID Application
CSC_NAME=
